SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

SAP_CHECK_CALLBACK_URL=http://localhost:3000/api/admin/mds/sap-check/callback
SAP_CHECK_CALLBACK_TOKEN=change-me

SAP_WEB_URL=https://sap-web.example.com
SAP_HEADLESS=false
SAP_CHECK_POLL_SECONDS=10
SAP_TIMEOUT_MS=15000
SAP_NAV_TIMEOUT_MS=30000
SAP_PLAYWRIGHT_PROFILE=.sap-playwright-profile
SAP_CHECK_WORKER_HOST=127.0.0.1
SAP_CHECK_WORKER_PORT=8765
SAP_CHECK_WORKER_CORS_ORIGIN=*

# SAP WebGUI mode. This is the recommended mode for SAP GUI for HTML.
# Example URL pattern from the working script:
# https://ui5ce.volvo.com/sap/bc/gui/sap/its/webgui?~transaction={tcode}#
SAP_WEBGUI_BASE_URL=https://ui5ce.volvo.com/sap/bc/gui/sap/its/webgui?~transaction={tcode}#
SAP_WEBGUI_TCODE=
SAP_MATERIAL_FIELD_NAME=Material Number
SAP_VENDOR_FIELD_NAME=Vendor
SAP_PLANT_FIELD_NAME=Plant
SAP_PLANT_VALUE=
SAP_PURCH_ORG_FIELD_NAME=Purch. Organization
SAP_PURCH_ORG_VALUE=
SAP_EXECUTE_BUTTON_NAME=Execute  Emphasized
SAP_LOGIN_TCODE=
SAP_LOGIN_READY_FIELD_NAME=Material Number
SAP_LOGIN_WAIT_SECONDS=120

# Optional login. Leave SAP_USER/SAP_PASSWORD empty when SSO/persistent profile handles login.
# If SAP WebGUI shows a login page and your account is allowed for automation,
# fill SAP_USER/SAP_PASSWORD and either selectors or accessible field names.
SAP_USER=
SAP_PASSWORD=
SAP_USER_SELECTOR=
SAP_PASSWORD_SELECTOR=
SAP_LOGIN_SUBMIT_SELECTOR=
SAP_USER_FIELD_NAME=
SAP_PASSWORD_FIELD_NAME=
SAP_LOGIN_BUTTON_NAME=Log On

# Option A: Direct URL template, if SAP Web supports queryable routes.
# Available placeholders: {part_number}, {supplier_code}, {action_type}
SAP_QUERY_URL_TEMPLATE=

# Option B: Form selectors, if the worker must fill a SAP Web screen.
SAP_PART_SELECTOR=
SAP_SUPPLIER_SELECTOR=
SAP_SEARCH_SELECTOR=

# Result selectors.
SAP_INFO_RECORD_SELECTOR=
SAP_DELETION_FLAG_SELECTOR=
SAP_STATUS_MESSAGE_SELECTOR=

# Result text fallback. Used when selectors are hard to keep stable in SAP WebGUI.
SAP_NO_DATA_REGEX=No\s+data\s+satisfying|No\s+list\s+entries|not\s+found|does\s+not\s+exist
SAP_INFO_RECORD_REGEX=
SAP_DELETION_FLAG_TRUE_REGEX=
SAP_DELETION_FLAG_FALSE_REGEX=
